rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────────────────────────
    // Helpers
    // ───────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin = role==admin in their user doc, OR email in hardcoded fallback list
    // (must stay in sync with src/constants.ts ADMIN_EMAILS).
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (
          request.auth.token.email_verified == true &&
          request.auth.token.email in [
            'ian@osensetech.com',
            'sienna@osensetech.com'
          ]
        )
      );
    }

    // True when the *existing* doc is owned by the caller (resource.data already exists).
    function isResourceOwner(field) {
      return isAuthenticated() && resource.data[field] == request.auth.uid;
    }

    // True when the *new* doc claims its owner field == the caller.
    function isNewOwner(field) {
      return isAuthenticated() && request.resource.data[field] == request.auth.uid;
    }

    // ───────────────────────────────────────────────────────────────
    // qa_items — collaborative; delete restricted to author/admin
    // ───────────────────────────────────────────────────────────────
    function isValidQAItem(data) {
      return data.keys().hasAll(['id', 'date', 'module', 'tester', 'description', 'imageLink', 'currentFlow', 'assignee', 'answer']) &&
             data.id is string && data.id.size() < 100 &&
             data.date is string && data.date.size() < 100 &&
             data.module is string && data.module.size() < 100 &&
             data.tester is string && data.tester.size() < 100 &&
             data.description is string && data.description.size() < 10000 &&
             data.imageLink is string && data.imageLink.size() < 1000 &&
             data.currentFlow is string && data.currentFlow.size() < 100 &&
             data.assignee is string && data.assignee.size() < 100 &&
             data.answer is string && data.answer.size() < 10000;
    }

    match /qa_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQAItem(request.resource.data);
      // Team members can update (status changes, retest, etc).
      allow update: if isAuthenticated();
      // Delete locked to original author or admin.
      allow delete: if isAuthenticated() && (
        !('authorUID' in resource.data) ||
        resource.data.authorUID == request.auth.uid ||
        isAdmin()
      );

      match /history/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        // History is append-only audit; no update/delete unless admin.
        allow update, delete: if isAdmin();
      }

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        // Caller must claim themselves as the author (prevents impersonation).
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasAll(['userId', 'userName', 'text', 'createdAt']) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.userName is string && request.resource.data.userName.size() < 100 &&
          request.resource.data.text is string && request.resource.data.text.size() < 5000 &&
          request.resource.data.createdAt is number;
        // Edit/delete only by the comment author or admin.
        allow update: if isAuthenticated() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.text is string && request.resource.data.text.size() < 5000;
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid || isAdmin()
        );
      }
    }

    // ───────────────────────────────────────────────────────────────
    // notifications — strict per-recipient
    // ───────────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      // Only the recipient can read/update/delete their own notifications.
      allow read, update, delete: if isResourceOwner('userId');
      // Sender can create a notification for someone else, but the sender
      // identity in the doc must match the caller (no impersonation).
      allow create: if isAuthenticated() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.userId is string;
    }

    // ───────────────────────────────────────────────────────────────
    // users — only owner or admin can write
    // ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users need to read each other's profile (name, photo, tier) for UI.
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /coinTransactions/{txId} {
        // Coin history is private to the owner.
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        // Tx are immutable once written.
        allow update, delete: if isAdmin();
      }
    }

    // ───────────────────────────────────────────────────────────────
    // daily_reports — owner-bound
    // ───────────────────────────────────────────────────────────────
    match /daily_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNewOwner('userId');
      allow update: if isAuthenticated() &&
        isResourceOwner('userId') &&
        request.resource.data.userId == resource.data.userId;
      allow delete: if isResourceOwner('userId') || isAdmin();
    }

    // ───────────────────────────────────────────────────────────────
    // wiki_pages — collaborative; delete locked
    // ───────────────────────────────────────────────────────────────
    match /wiki_pages/{pageId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ───────────────────────────────────────────────────────────────
    // releases — collaborative; delete locked
    // ───────────────────────────────────────────────────────────────
    match /releases/{releaseId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ───────────────────────────────────────────────────────────────
    // todos — already had owner check on delete
    // ───────────────────────────────────────────────────────────────
    match /todos/{todoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() &&
        (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // ───────────────────────────────────────────────────────────────
    // achievement_logs — write-once per (userId, achievementId)
    // ───────────────────────────────────────────────────────────────
    match /achievement_logs/{logId} {
      allow read: if isAuthenticated();
      // Caller can only create achievement logs for themselves.
      allow create: if isAuthenticated() && isNewOwner('userId');
      // Achievements are immutable.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────────────────────
    // meeting_notes — collaborative; delete locked
    // ───────────────────────────────────────────────────────────────
    match /meeting_notes/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ───────────────────────────────────────────────────────────────
    // roadmap_items — collaborative; delete locked
    // ───────────────────────────────────────────────────────────────
    match /roadmap_items/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ───────────────────────────────────────────────────────────────
    // decisions — collaborative; delete locked
    // ───────────────────────────────────────────────────────────────
    match /decisions/{decisionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
    }

    // ───────────────────────────────────────────────────────────────
    // audit_logs — append-only; entries are tamper-evident via userId pinning
    // ───────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Clients can append entries about their own actions only.
      // Once written, entries are immutable to all clients.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'action', 'createdAt']) &&
        request.resource.data.action is string &&
        request.resource.data.action.size() < 200 &&
        request.resource.data.createdAt is number;
      allow update, delete: if isAdmin();
    }
  }
}
