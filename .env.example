# All secrets are SERVER-SIDE only. Do NOT prefix with VITE_ unless you intend
# the value to be embedded in the public client bundle.

# Gemini API key (server-side proxy at /api/ai/generate)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ImgBB API key (server-side proxy at /api/imgbb/upload)
IMGBB_API_KEY="YOUR_IMGBB_API_KEY"

# Slack Bot token (server-side, used by /api/slack/notify)
SLACK_BOT_TOKEN="xoxb-YOUR-SLACK-BOT-TOKEN"

# Firebase Admin service account JSON (one-line JSON string).
# Used to verify ID tokens on the server. Without this we can still verify
# tokens using project-id only, but server-side Firestore writes require it.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Comma-separated list of allowed CORS origins (defaults include localhost + Render URL)
# CORS_ORIGINS="https://your-domain.com,https://another.com"

# Server port (defaults to 3000)
# PORT=3000

# APP_URL: optional self-reference URL (Cloud Run / Render URL)
APP_URL="MY_APP_URL"
